# =============================================================================
# Duurzame-Vlaggen.nl — environment variables (build spec §2)
#
# Copy to `.env.local` for local dev and fill in TEST values.
# Set PRODUCTION values in the Vercel project settings — keep test & prod separate.
# NEVER commit real values. `.env*` is gitignored.
#
# Rule: anything without a NEXT_PUBLIC_ prefix is server-only and must never
# reach the browser.
# =============================================================================

# --- Server-only secrets -----------------------------------------------------

# Mollie — use test_... for dev, live_... for production.
MOLLIE_API_KEY=

# Supabase — privileged server-side key. Never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Admin back-office (/admin) — comma-separated staff e-mails allowed to sign in.
# Only these addresses pass the auth-gate; empty locks everyone out.
# Create the matching Supabase Auth user with: npx tsx scripts/create-admin.ts <email> <password>
ADMIN_EMAILS=

# Resend — transactionele e-mail (materiaalpaspoort-PDF bij elke betaalde order).
# OPTIONEEL: laat leeg om de paspoort-mail over te slaan (wordt gelogd, geen crash).
# Zet in productie een echte key (re_...) om de mails daadwerkelijk te versturen.
RESEND_API_KEY=
# Afzenderadres voor uitgaande e-mail. Formaat: "Naam <adres@domein>".
# Domein moet in Resend geverifieerd zijn. Leeg → net standaardadres als fallback.
MAIL_FROM=Duurzame Vlaggen <hello@duurzame-vlaggen.nl>

# Google Search Console — voedt /admin/analytics (SEO-kansen, migratie-risico).
# OPTIONEEL: leeg laten ⇒ de analytics-pagina toont een setup-melding, geen crash.
# Aanmaken: Google Cloud → service-account → JSON-key → Search Console API aanzetten.
# Daarna in Search Console het service-account als GEBRUIKER toevoegen op de
# property, anders antwoordt Google met 403.
GSC_CLIENT_EMAIL=
# De private_key uit de service-account-JSON. Regeleindes mogen als letterlijke
# \n blijven staan (de code vervangt ze); zet de waarde tussen quotes.
GSC_PRIVATE_KEY=
# De property zoals Search Console 'm kent. Voorkeur: de domein-property, want
# die overleeft de WordPress→Next-migratie en dekt www + non-www.
#   sc-domain:duurzame-vlaggen.nl     of     https://duurzame-vlaggen.nl/
GSC_SITE_URL=sc-domain:duurzame-vlaggen.nl

# --- Public (safe for the client) --------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Canonical app URL — used to build Mollie callback & return URLs.
# Dev example: http://localhost:3000
NEXT_PUBLIC_APP_URL=

# Interne inbox voor portaal-notificaties; default: eerste ADMIN_EMAILS-adres.
ORDER_NOTIFY_EMAIL=
# Beveiligt de cron-routes (/api/cron/*). Vercel stuurt hem automatisch mee
# als "Authorization: Bearer <CRON_SECRET>" wanneer hij als env-var bestaat.
CRON_SECRET=
# HMAC-secret voor ondertekende e-maillinks (uitschrijven). Lange random string.
EMAIL_LINK_SECRET=
