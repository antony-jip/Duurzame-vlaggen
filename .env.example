# =============================================================================
# Duurzame-Vlaggen.nl — environment variables (build spec §2)
#
# Copy to `.env.local` for local dev and fill in TEST values.
# Set PRODUCTION values in the Vercel project settings — keep test & prod separate.
# NEVER commit real values. `.env*` is gitignored.
#
# Rule: anything without a NEXT_PUBLIC_ prefix is server-only and must never
# reach the browser.
# =============================================================================

# --- Server-only secrets -----------------------------------------------------

# Probo — Reseller API (https://api.proboprints.com)
# PROBO_API_KEY is a base64 "id:secret" token = HTTP Basic auth. It is already
# encoded; the code sends `Authorization: Basic <PROBO_API_KEY>`. Do NOT re-encode.
PROBO_API_KEY=
# Value for verifying inbound Probo status callbacks (X-Security-Header).
PROBO_SECURITY_TOKEN=
# Optional override; defaults to https://api.proboprints.com when unset.
PROBO_API_BASE_URL=

# Mollie — use test_... for dev, live_... for production.
MOLLIE_API_KEY=

# Supabase — privileged server-side key. Never exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- Public (safe for the client) --------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Canonical app URL — used to build Mollie/Probo callback & return URLs.
# Dev example: http://localhost:3000
NEXT_PUBLIC_APP_URL=
